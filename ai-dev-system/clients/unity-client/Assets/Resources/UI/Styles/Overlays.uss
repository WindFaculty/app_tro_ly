.subtitle-card {
    position: absolute;
    bottom: 40px;
    align-self: center;
    background-color: rgba(10, 13, 20, 0.85);
    padding: 16px 24px;
    border-radius: var(--radius-lg);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    max-width: 80%;
    transition-duration: 0.3s;
    transition-property: opacity, translate;
}

.subtitle-text {
    color: var(--color-text-main);
    font-size: 16px;
    -unity-font-style: italic;
    white-space: normal;
    -unity-text-align: middle-center;
}

.reminder-card {
    position: absolute;
    bottom: 40px;
    right: 32px;
    width: 300px;
    background-color: var(--color-panel-dark);
    padding: 20px;
    border-radius: var(--radius-lg);
    border-width: 1px;
    border-color: var(--color-primary-cyan);
    transition-duration: 0.3s;
    transition-property: opacity, translate;
}

.reminder-header {
    -unity-font-style: bold;
    color: var(--color-text-main);
    margin-bottom: 8px;
    font-size: 15px;
}

.reminder-text {
    color: var(--color-text-dim);
    white-space: normal;
    font-size: 14px;
    line-height: 20px;
}

.hidden {
    opacity: 0;
    translate: 0 20px;
}
