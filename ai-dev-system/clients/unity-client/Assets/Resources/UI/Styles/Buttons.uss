.tab-button {
    min-width: 96px;
    padding: 10px 0;
    margin: 0 18px;
    border-width: 0;
    border-radius: 0;
    background-color: transparent;
    color: var(--color-text-dim);
    font-size: 15px;
    -unity-font-style: bold;
    border-bottom-width: 2px;
    border-bottom-color: transparent;
}

.tab-button:hover {
    color: var(--color-text-main);
}

.tab-button.active {
    color: var(--color-primary-cyan);
    border-bottom-color: var(--color-primary-cyan);
}

.notif-btn {
    min-width: 64px;
    height: 38px;
    margin-right: var(--space-3);
    border-width: 1px;
    border-color: var(--color-border-soft);
    border-radius: var(--radius-pill);
    background-color: var(--color-panel-dark);
    color: var(--color-text-main);
}

.notif-btn:hover {
    border-color: var(--color-border-strong);
    color: var(--color-primary-cyan);
}

.sidebar-menu-btn {
    min-height: 46px;
    margin-bottom: var(--space-2);
    padding: 12px 16px;
    border-width: 0;
    border-radius: var(--radius-md);
    background-color: transparent;
    color: var(--color-text-dim);
    flex-direction: row;
    justify-content: space-between;
    -unity-text-align: middle-left;
    font-size: 14px;
}

.sidebar-menu-btn:hover {
    background-color: var(--color-panel-dark);
    color: var(--color-text-main);
}

.sidebar-menu-btn.active {
    background-color: var(--color-panel-mid);
    color: var(--color-text-main);
    border-left-width: 3px;
    border-left-color: var(--color-primary-cyan);
}

.btn-primary {
    min-height: 40px;
    padding: 10px 16px;
    border-width: 0;
    border-radius: var(--radius-md);
    background-color: var(--color-primary-cyan);
    color: #03131b;
    -unity-font-style: bold;
}

.btn-primary:hover {
    background-color: var(--color-primary-cyan-hover);
}

.btn-secondary {
    min-height: 40px;
    padding: 10px 16px;
    border-width: 1px;
    border-color: var(--color-border-soft);
    border-radius: var(--radius-md);
    background-color: var(--color-panel-dark);
    color: var(--color-text-main);
}

.btn-secondary:hover {
    border-color: var(--color-border-strong);
}

.chat-btn {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-pill);
    justify-content: center;
    align-items: center;
    background-color: rgba(255, 255, 255, 0.05);
    border-width: 0;
    color: white;
    font-size: 18px;
}

.chat-btn.primary {
    background-color: var(--color-primary-cyan);
    color: #03131b;
}

.chat-btn:hover {
    background-color: rgba(255, 255, 255, 0.1);
}
