.shell-card {
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    background-color: var(--color-panel-dark);
    border-width: 1px;
    border-color: var(--color-border-soft);
}

.accent-card {
    margin-bottom: var(--space-3);
    background-color: var(--color-panel-mid);
    border-color: var(--color-border-strong);
}

.assistant-mini-card {
    margin-bottom: var(--space-3);
    background-color: var(--color-panel-dark);
}

.assistant-mini-time {
    color: var(--color-primary-cyan);
    font-size: var(--font-size-sm);
    -unity-font-style: bold;
    margin-bottom: var(--space-1);
}

.assistant-mini-title {
    color: var(--color-text-main);
    font-size: 16px;
    -unity-font-style: bold;
    margin-bottom: var(--space-1);
}

.assistant-mini-copy {
    color: var(--color-text-dim);
    white-space: normal;
    line-height: 18px;
}

.health-banner {
    margin-bottom: var(--space-4);
}

.health-title {
    color: var(--color-primary-cyan);
    font-size: var(--font-size-kicker);
    -unity-font-style: bold;
    margin-bottom: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 1px;
}

.health-value {
    font-size: 17px;
    -unity-font-style: bold;
    margin-bottom: var(--space-2);
}

.health-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-dim);
    white-space: normal;
    line-height: 18px;
}

.settings-panel {
    flex-grow: 1;
}

.settings-header {
    font-size: 32px;
    -unity-font-style: bold;
    margin-bottom: 8px;
}

.settings-desc {
    color: var(--color-text-dim);
    margin-bottom: 32px;
}

.settings-card {
    background-color: var(--color-panel-dark);
    border-radius: var(--radius-lg);
    padding: 24px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.05);
}

.settings-card-header {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
}

.settings-card-title {
    font-size: 18px;
    -unity-font-style: bold;
}

.settings-action-row {
    flex-direction: row;
    justify-content: flex-end;
    margin-top: 24px;
}
