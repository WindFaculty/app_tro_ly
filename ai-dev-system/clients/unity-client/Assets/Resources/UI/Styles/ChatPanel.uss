.chat-panel-container {
    flex-direction: column;
    height: 100%;
    min-height: 0;
    flex-shrink: 1;
    background-color: var(--color-bg-dark);
}

.chat-header {
    flex-shrink: 0;
    padding: 16px 24px;
    border-bottom-width: 1px;
    border-bottom-color: rgba(255, 255, 255, 0.05);
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    background-color: var(--color-panel-dark);
}

.chat-title {
    font-size: 15px;
    -unity-font-style: bold;
    color: var(--color-text-main);
    letter-spacing: 0.5px;
    margin: 0 0 4px;
    padding: 0;
}

.chat-subtitle {
    font-size: 11px;
    color: var(--color-text-dim);
    letter-spacing: 1px;
    margin: 0;
    padding: 0;
}

.chat-model-badge {
    background-color: rgba(6, 182, 212, 0.15);
    color: var(--color-primary-cyan);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    font-size: 11px;
    -unity-font-style: bold;
    border-width: 1px;
    border-color: rgba(6, 182, 212, 0.3);
}

.chat-status-strip {
    flex-shrink: 0;
    padding: 18px 24px 10px;
    flex-direction: column;
    gap: 12px;
}

.chat-status-card {
    flex-grow: 1;
    background-color: rgba(255, 255, 255, 0.04);
    border-radius: var(--radius-md);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.06);
    padding: 16px;
}

.chat-status-card-primary {
    min-width: 280px;
}

.chat-state-badge {
    align-self: flex-start;
    background-color: rgba(6, 182, 212, 0.16);
    color: var(--color-primary-cyan);
    border-radius: 999px;
    padding: 4px 10px;
    font-size: 11px;
    letter-spacing: 1px;
    -unity-font-style: bold;
    margin: 0 0 10px;
}

.chat-state-title {
    font-size: 16px;
    -unity-font-style: bold;
    color: var(--color-text-main);
    margin: 0 0 8px;
    padding: 0;
}

.chat-state-detail {
    font-size: 12px;
    line-height: 18px;
    color: var(--color-text-dim);
    white-space: normal;
    margin: 0;
    padding: 0;
}

.chat-status-side {
    flex-grow: 1;
    gap: 12px;
}

.chat-info-card {
    flex-grow: 1;
    min-height: 88px;
    background-color: rgba(255, 255, 255, 0.025);
    border-radius: var(--radius-md);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.05);
    padding: 14px 16px;
}

.chat-info-title {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 8px;
    padding: 0;
}

.chat-info-body {
    font-size: 12px;
    line-height: 18px;
    color: var(--color-text-main);
    white-space: normal;
    margin: 0;
    padding: 0;
}

.chat-log-scroll {
    flex-grow: 1;
    padding: 8px 24px 16px;
}

.chat-log-caption {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
    margin: 0 0 10px;
    padding: 0;
}

.chat-log-text {
    white-space: normal;
    font-size: 14px;
    line-height: 24px;
    color: var(--color-text-main);
}

.chat-input-area {
    flex-shrink: 0;
    padding: 16px 24px;
    background-color: var(--color-panel-dark);
    flex-direction: row;
    align-items: flex-end;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.05);
}

.chat-input-field {
    flex-grow: 1;
    margin: 0;
    padding: 0;
}

.chat-input-field > .unity-text-field__input {
    background-color: rgba(255, 255, 255, 0.05);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    color: var(--color-text-main);
    font-size: 14px;
    white-space: normal;
    -unity-text-align: middle-left;
}

.chat-input-field > .unity-text-field__input:focus {
    border-color: var(--color-primary-cyan);
    background-color: rgba(255, 255, 255, 0.08);
}

.chat-input-actions {
    flex-direction: row;
    margin-left: 12px;
}

.chat-btn {
    min-width: 68px;
    height: 44px;
    border-radius: var(--radius-sm);
    border-width: 0;
    font-size: 13px;
    -unity-font-style: bold;
    transition-property: background-color;
    transition-duration: 0.2s;
    margin: 0;
    padding: 0 14px;
}

.mic-btn {
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--color-text-main);
    margin-right: 8px;
}

.mic-btn:hover {
    background-color: rgba(255, 255, 255, 0.15);
}

.send-btn {
    background-color: var(--color-primary-cyan);
    color: var(--color-bg-dark);
}

.send-btn:hover {
    background-color: var(--color-primary-cyan-hover);
}
