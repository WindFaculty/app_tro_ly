.layout-container {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg-dark);
    width: 100%;
    height: 100%;
    min-height: 100%;
}

.shell-root {
    position: relative;
    padding: var(--space-4);
    min-height: 100%;
}

.shell-surface {
    background-color: var(--color-bg-elevated);
    border-width: 1px;
    border-color: var(--color-border-soft);
.shell-four-zone {
    overflow: hidden;
}

.shell-main-row {
    flex-grow: 1;
    flex-direction: row;
    min-height: 0;
}

.brand-mark {
    width: 44px;
    height: 44px;
    justify-content: center;
    align-items: center;
    margin-bottom: var(--space-3);
    border-radius: var(--radius-md);
    background-color: var(--color-primary-cyan-soft);
    border-width: 1px;
    border-color: var(--color-border-strong);
}

.brand-mark Label {
    color: var(--color-primary-cyan);
    -unity-font-style: bold;
    font-size: var(--font-size-lg);
}

.control-rail {
    width: 132px;
    min-width: 132px;
    flex-shrink: 0;
    margin-right: var(--space-4);
    padding: 18px 14px;
    border-radius: var(--radius-xl);
    flex-direction: column;
}

.rail-brand {
    align-items: center;
    margin-bottom: var(--space-4);
}

.rail-brand-title {
    color: var(--color-text-main);
    -unity-font-style: bold;
    font-size: 18px;
}

.rail-brand-subtitle {
    margin-top: 2px;
    color: var(--color-text-dim);
    font-size: 11px;
    letter-spacing: 1px;
}

.rail-status-stack {
    flex-direction: column;
    margin-bottom: var(--space-4);
}

.rail-status-card {
    margin-bottom: var(--space-3);
    padding: 12px 12px 10px;
    border-radius: var(--radius-md);
    background-color: rgba(255, 255, 255, 0.03);
    border-width: 1px;
    border-color: var(--color-border-soft);
}

.sidebar-section-title {
    margin-bottom: var(--space-2);
    color: var(--color-text-dim);
    font-size: var(--font-size-kicker);
    text-transform: uppercase;
    letter-spacing: 1px;
    -unity-font-style: bold;
}

.health-value {
    color: var(--color-text-main);
    -unity-font-style: bold;
    margin-bottom: 4px;
}

.sidebar-status-value {
    color: var(--color-primary-cyan);
    font-size: var(--font-size-sm);
    -unity-font-style: bold;
}

.rail-control-stack {
    flex-direction: column;
}

.rail-action-button {
    min-height: 56px;
    margin-bottom: var(--space-3);
    border-radius: 18px;
    background-color: rgba(255, 255, 255, 0.035);
    border-width: 1px;
    border-color: var(--color-border-soft);
    color: var(--color-text-main);
    -unity-font-style: bold;
}

.rail-action-button.active {
    background-color: rgba(6, 182, 212, 0.16);
    border-color: rgba(6, 182, 212, 0.36);
    color: var(--color-primary-cyan);
}

.shell-spacer {
    flex-grow: 1;
}

.shell-help-card {
    padding: 14px;
}

.rail-footer-card {
    background-color: rgba(255, 255, 255, 0.025);
}

.shell-help-text {
    margin-bottom: var(--space-3);
    color: var(--color-text-dim);
    white-space: normal;
    line-height: 18px;
}

.stage-column {
    flex-grow: 1;
    min-height: 0;
    flex-direction: column;
    margin-right: var(--space-4);
}

.stage-header {
    min-height: 116px;
    margin-bottom: var(--space-4);
    padding: 18px 22px;
    border-radius: var(--radius-xl);
    flex-direction: row;
    align-items: stretch;
}

.stage-header-copy {
    flex-grow: 1;
    margin-right: var(--space-4);
}

.stage-header-status {
    width: 320px;
}

.center-stage {
    flex-grow: 1;
    min-height: 0;
}

.stage-shell {
    border-radius: var(--radius-xl);
    background-color: rgba(255, 255, 255, 0.01);
    overflow: hidden;
}

.view-container {
    flex-grow: 1;
    display: flex;
    min-height: 0;
    flex-shrink: 1;
}

.calendar-sheet {
    flex-shrink: 0;
    margin-top: var(--space-4);
    padding: 16px 18px 18px;
    border-radius: var(--radius-xl);
    flex-direction: column;
    overflow: hidden;
    transition-property: height;
    transition-duration: 0.18s;
}

.calendar-sheet-collapsed {
    height: 228px;
}

.calendar-sheet-expanded {
    height: 420px;
}

.calendar-sheet-header {
    flex-shrink: 0;
    margin-bottom: var(--space-3);
}

.calendar-sheet-header-copy {
    flex-direction: column;
}

.right-panel {
    width: 408px;
    min-width: 408px;
    flex-shrink: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    min-height: 0;
}

.settings-scrim {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(2, 6, 23, 0.58);
}

.settings-drawer {
    position: absolute;
    top: 20px;
    right: 20px;
    bottom: 20px;
    width: 520px;
    padding: 18px;
    border-radius: 28px;
    background-color: rgba(11, 19, 34, 0.97);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    flex-direction: column;
}

.settings-drawer-header {
    flex-shrink: 0;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-4);
}

.panel-kicker {
    color: var(--color-primary-cyan);
    font-size: var(--font-size-kicker);
    text-transform: uppercase;
    letter-spacing: 1px;
    -unity-font-style: bold;
    margin-bottom: var(--space-1);
}

.panel-title {
    color: var(--color-text-main);
    font-size: var(--font-size-xl);
    -unity-font-style: bold;
    margin-bottom: var(--space-2);
}

.panel-body {
    color: var(--color-text-soft);
    white-space: normal;
    line-height: 20px;
}

.panel-meta {
    color: var(--color-text-soft);
    white-space: normal;
    line-height: 19px;
}

.stack-card-list {
    flex-direction: column;
}

.shell-muted-label {
    color: var(--color-text-dim);
}

.schedule-screen {
    flex-direction: column;
}

.schedule-title {
    font-size: 30px;
    -unity-font-style: bold;
    margin-bottom: var(--space-2);
}

.schedule-summary {
    margin-bottom: var(--space-4);
    color: var(--color-text-soft);
    white-space: normal;
    line-height: 20px;
}

.schedule-toolbar {
    flex-direction: row;
    align-items: center;
    margin-bottom: var(--space-4);
}

.schedule-toolbar-date-nav {
    flex-direction: row;
    margin-right: var(--space-3);
}

.schedule-toolbar-date-nav Button {
    margin-right: var(--space-2);
}

.schedule-toolbar-actions {
    flex-direction: row;
}

.schedule-toolbar-actions Button {
    margin-right: var(--space-2);
}

.schedule-month-label {
    flex-grow: 1;
    font-size: 20px;
    -unity-font-style: bold;
    color: var(--color-text-main);
}

.schedule-canvas {
    flex-grow: 1;
    padding: var(--space-4);
    border-radius: var(--radius-xl);
    background-color: var(--color-bg-elevated);
    border-width: 1px;
    border-color: var(--color-border-soft);
}

.schedule-meta {
    margin-bottom: var(--space-3);
    color: var(--color-text-dim);
    white-space: normal;
    line-height: 18px;
}

.schedule-empty-state {
    margin-bottom: var(--space-3);
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background-color: rgba(255, 255, 255, 0.03);
    color: var(--color-text-dim);
    white-space: normal;
}

.schedule-list-container {
    flex-direction: column;
}

.schedule-day-card {
    margin-bottom: var(--space-3);
    background-color: var(--color-panel-dark);
}

.schedule-day-card-selected {
    border-color: var(--color-border-strong);
    background-color: rgba(60, 200, 232, 0.08);
}

.schedule-day-header {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
}

.schedule-day-select-btn {
    flex-grow: 1;
    margin-right: var(--space-2);
    padding: 0;
    background-color: transparent;
    border-width: 0;
    -unity-text-align: middle-left;
}

.schedule-day-select-btn:hover {
    background-color: transparent;
}

.schedule-day-title {
    font-size: 18px;
    -unity-font-style: bold;
    color: var(--color-text-main);
}

.schedule-day-count {
    padding: 4px 10px;
    border-radius: var(--radius-pill);
    background-color: rgba(60, 200, 232, 0.16);
    color: var(--color-primary-cyan);
    font-size: var(--font-size-sm);
    -unity-font-style: bold;
}

.schedule-day-meta {
    margin-bottom: var(--space-2);
    color: var(--color-text-dim);
    font-size: var(--font-size-sm);
}

.schedule-task-row {
    margin-bottom: var(--space-2);
    padding: 10px 12px;
    border-radius: var(--radius-md);
    background-color: rgba(255, 255, 255, 0.03);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.04);
}

.schedule-task-content {
    flex-grow: 1;
}

.schedule-task-layout {
    flex-direction: row;
    align-items: flex-start;
}

.schedule-task-actions {
    margin-left: var(--space-3);
    flex-direction: column;
    align-items: flex-end;
}

.schedule-task-action-btn {
    min-width: 124px;
    margin-bottom: var(--space-2);
}

.schedule-task-title {
    color: var(--color-text-main);
    -unity-font-style: bold;
    white-space: normal;
    margin-bottom: 4px;
}

.schedule-task-meta {
    color: var(--color-text-dim);
    font-size: var(--font-size-sm);
    white-space: normal;
    line-height: 17px;
}

.schedule-task-empty,
.schedule-task-more {
    color: var(--color-text-dim);
    font-size: var(--font-size-sm);
}
