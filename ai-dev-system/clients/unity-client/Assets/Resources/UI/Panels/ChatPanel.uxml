<?xml version="1.0" encoding="utf-8"?>
<ui:UXML
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ui="UnityEngine.UIElements"
    xmlns:editor="UnityEditor.UIElements"
    xsi:noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd"
>
    <ui:VisualElement name="ChatPanelView" class="view-container chat-panel-container">
        <ui:VisualElement class="chat-header">
            <ui:VisualElement class="chat-header-titles">
                <ui:Label text="Luminal Assistant" class="chat-title" />
                <ui:Label text="SYSTEM CORE ONLINE" class="chat-subtitle" />
            </ui:VisualElement>
            <ui:Label name="ChatRouteBadge" text="Route pending" class="chat-model-badge" />
        </ui:VisualElement>

        <ui:VisualElement class="chat-status-strip">
            <ui:VisualElement class="chat-status-card chat-status-card-primary">
                <ui:Label name="ChatStateBadge" text="READY" class="chat-state-badge" />
                <ui:Label name="ChatStateTitle" text="Ready for the next turn" class="chat-state-title" />
                <ui:Label name="ChatStateDetail" text="Routing diagnostics and transcript state will appear here." class="chat-state-detail" />
            </ui:VisualElement>

            <ui:VisualElement class="chat-status-side">
                <ui:VisualElement class="chat-info-card">
                    <ui:Label name="ChatTranscriptPreviewTitle" text="Transcript preview" class="chat-info-title" />
                    <ui:Label name="ChatTranscriptPreviewText" text="Start the mic to inspect captured speech here." class="chat-info-body" />
                </ui:VisualElement>

                <ui:VisualElement class="chat-info-card">
                    <ui:Label name="ChatActionSummaryTitle" text="Action confirmation" class="chat-info-title" />
                    <ui:Label name="ChatActionSummaryText" text="Task changes triggered from chat will appear here." class="chat-info-body" />
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>

        <ui:ScrollView class="chat-log-scroll" vertical-scroller-visibility="Auto">
            <ui:Label text="Conversation" class="chat-log-caption" />
            <ui:Label name="ChatLogText" class="chat-log-text" text="" />
        </ui:ScrollView>

        <ui:VisualElement class="chat-input-area">
            <ui:TextField name="ChatInput" class="chat-input-field" placeholder-text="Nhap yeu cau cua ban..." />
            <ui:VisualElement class="chat-input-actions">
                <ui:Button name="MicButton" text="Mic" class="chat-btn mic-btn" />
                <ui:Button name="SendButton" text="Send" class="chat-btn send-btn" />
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
