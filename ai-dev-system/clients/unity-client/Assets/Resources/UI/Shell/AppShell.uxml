<?xml version="1.0" encoding="utf-8"?>
<ui:UXML
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ui="UnityEngine.UIElements"
    xmlns:editor="UnityEditor.UIElements"
    xsi:noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd"
>
    <ui:Style src="../Styles/Tokens.uss" />
    <ui:Style src="../Styles/Layout.uss" />
    <ui:Style src="../Styles/Buttons.uss" />
    <ui:Style src="../Styles/Cards.uss" />
    <ui:Style src="../Styles/Forms.uss" />
    <ui:Style src="../Styles/HomeScreen.uss" />
    <ui:Style src="../Styles/ChatPanel.uss" />
    <ui:Template name="HomeScreenTemplate" src="../Screens/HomeScreen.uxml" />
    <ui:Template name="ScheduleScreenTemplate" src="../Screens/ScheduleScreen.uxml" />
    <ui:Template name="SettingsScreenTemplate" src="../Screens/SettingsScreen.uxml" />
    <ui:Template name="ChatPanelTemplate" src="../Panels/ChatPanel.uxml" />
    <ui:Template name="SubtitleOverlayTemplate" src="../Overlays/SubtitleOverlay.uxml" />
    <ui:Template name="ReminderOverlayTemplate" src="../Overlays/ReminderOverlay.uxml" />

    <ui:VisualElement class="layout-container shell-root shell-four-zone">
        <ui:VisualElement class="shell-main-row">
            <ui:VisualElement class="control-rail shell-surface">
                <ui:VisualElement class="rail-brand">
                    <ui:VisualElement class="brand-mark"><ui:Label text="TL" /></ui:VisualElement>
                    <ui:Label text="Tro Ly" class="rail-brand-title" />
                    <ui:Label text="Local shell" class="rail-brand-subtitle" />
                </ui:VisualElement>

                <ui:VisualElement class="rail-status-stack">
                    <ui:VisualElement class="rail-status-card">
                        <ui:Label text="Runtime" class="sidebar-section-title" />
                        <ui:Label name="TopStatusChipLabel" text="Loading runtime" class="health-value" />
                    </ui:VisualElement>

                    <ui:VisualElement class="rail-status-card">
                        <ui:Label text="Health" class="sidebar-section-title" />
                        <ui:Label name="HealthBanner" text="Loading runtime" class="health-value" />
                        <ui:Label name="AvatarStateText" text="Idle" class="sidebar-status-value" />
                    </ui:VisualElement>
                </ui:VisualElement>

                <ui:VisualElement class="rail-control-stack">
                    <ui:Button name="FocusStageButton" text="Stage" class="rail-action-button active" />
                    <ui:Button name="ToggleCalendarButton" text="Planner" class="rail-action-button" />
                    <ui:Button name="ToggleChatButton" text="Chat" class="rail-action-button active" />
                    <ui:Button name="ToggleSettingsButton" text="Settings" class="rail-action-button" />
                </ui:VisualElement>

                <ui:VisualElement class="shell-spacer" />

                <ui:VisualElement class="shell-card shell-help-card rail-footer-card">
                    <ui:Label text="Refresh workspace after backend restarts or runtime changes." class="shell-help-text" />
                    <ui:Button name="RefreshButton" text="Refresh" class="btn-secondary" />
                </ui:VisualElement>
            </ui:VisualElement>

            <ui:VisualElement class="stage-column">
                <ui:VisualElement class="stage-header shell-surface">
                    <ui:VisualElement class="stage-header-copy">
                        <ui:Label name="ScheduleInsightTitle" text="Week overview" class="panel-title" />
                        <ui:Label name="ScheduleInsightSummary" text="Keep the planner sheet close while the assistant routes chat, voice, and reminders." class="panel-body" />
                    </ui:VisualElement>
                    <ui:VisualElement class="stage-header-status">
                        <ui:Label text="Assistant state" class="sidebar-section-title" />
                        <ui:Label name="StageStatusText" text="Loading runtime status..." class="panel-meta" />
                    </ui:VisualElement>
                </ui:VisualElement>

                <ui:VisualElement class="center-stage stage-shell">
                    <ui:Instance template="HomeScreenTemplate" />
                    <ui:Instance template="SubtitleOverlayTemplate" />
                </ui:VisualElement>

                <ui:VisualElement name="CalendarSheetHost" class="calendar-sheet shell-surface calendar-sheet-collapsed">
                    <ui:VisualElement class="calendar-sheet-header">
                        <ui:VisualElement class="calendar-sheet-header-copy">
                            <ui:Label text="Planner sheet" class="panel-kicker" />
                            <ui:Label name="ScheduleInsightMeta" text="Date auto&#10;Route planner | Provider local&#10;Voice Off | Transcript Off | Fallbacks 0" class="panel-meta" />
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:Instance template="ScheduleScreenTemplate" />
                </ui:VisualElement>
            </ui:VisualElement>

            <ui:VisualElement name="ChatPanelHost" class="right-panel shell-surface">
                <ui:Instance template="ChatPanelTemplate" class="view-container" />
            </ui:VisualElement>
        </ui:VisualElement>

        <ui:VisualElement name="SettingsScrim" class="settings-scrim hidden" />
        <ui:VisualElement name="SettingsDrawer" class="settings-drawer hidden">
            <ui:VisualElement class="settings-drawer-header">
                <ui:VisualElement>
                    <ui:Label text="Settings drawer" class="panel-kicker" />
                    <ui:Label text="Tune runtime behavior without leaving the four-zone shell." class="panel-body" />
                </ui:VisualElement>
                <ui:Button name="CloseSettingsButton" text="Close" class="btn-secondary" />
            </ui:VisualElement>
            <ui:Instance template="SettingsScreenTemplate" />
        </ui:VisualElement>

        <ui:Instance template="ReminderOverlayTemplate" />
    </ui:VisualElement>
</ui:UXML>
